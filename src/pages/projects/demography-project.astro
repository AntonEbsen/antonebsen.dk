    { label: "Data", value: "1851-1891" },
    { label: "Status", value: "I gang" }
  ],
  contextNote: "Projektet er mit afsluttende eksamensprojekt i faget Demografi på Københavns Universitet.",
  videoUrl: "", 
  techStack: [
      { name: "Økonometri", icon: "fa-solid fa-calculator" },
      { name: "Geospatial Analysis", icon: "fa-solid fa-map-location-dot" },
