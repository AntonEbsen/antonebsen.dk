---
import Card from './Card.astro';

interface Props {
  name: string;
  role: string;
  category: string;
  image?: string;
  quote: string;
  impact: string;
}

const { name, role, category, image, quote, impact } = Astro.props;

// Default image if none provided
const displayImage = image || "/assets/img/placeholder-influence.jpg";
---

<div class="influence-container group cursor-pointer h-[450px] w-full">
  <div class="influence-inner relative w-full h-full text-center transition-transform duration-700 preserve-3d group-hover:my-rotate-y-180 group-focus:my-rotate-y-180">
    
    <!-- FRONT -->
    <div class="influence-front absolute inset-0 backface-hidden rounded-2xl overflow-hidden border border-white/10 shadow-2xl">
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
      <img 
        src={displayImage} 
        alt={name} 
        class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" 
      />
      <div class="absolute bottom-6 left-6 right-6 z-20 text-left">
        <span class="text-[10px] uppercase tracking-widest text-accent font-bold mb-1 block">{category}</span>
        <h3 class="text-2xl font-bold text-white leading-tight">{name}</h3>
        <p class="text-sm text-white/70">{role}</p>
      </div>
      
      <!-- Flip Hint Icon -->
      <div class="absolute top-4 right-4 z-20 w-8 h-8 rounded-full bg-black/40 backdrop-blur-md flex items-center justify-center border border-white/10 opacity-0 group-hover:opacity-100 transition-opacity">
        <i class="fa-solid fa-rotate text-white/50 text-xs"></i>
      </div>
    </div>

    <!-- BACK -->
    <div class="influence-back absolute inset-0 backface-hidden my-rotate-y-180 rounded-2xl overflow-hidden border border-accent/30 bg-[#0a0a0a] shadow-2xl flex flex-col justify-center p-8">
      <!-- Decorative Background -->
      <div class="absolute inset-0 bg-gradient-to-br from-accent/5 to-purple-500/5 z-0"></div>
      
      <div class="relative z-10 text-left">
        <i class="fa-solid fa-quote-left text-3xl text-accent/20 mb-4 block"></i>
        <blockquote class="text-lg font-serif italic text-white/90 mb-6 leading-relaxed">
          "{quote}"
        </blockquote>
        
        <div class="w-12 h-0.5 bg-accent/30 mb-6"></div>
        
        <h4 class="text-xs uppercase tracking-widest text-accent font-bold mb-2">The Impact</h4>
        <p class="text-sm text-white/70 leading-relaxed">
          {impact}
        </p>
      </div>

      <!-- Return Hint -->
      <div class="absolute bottom-4 right-4 text-[10px] uppercase tracking-widest text-white/30">
        Hover out to return
      </div>
    </div>

  </div>
</div>

<style>
  .preserve-3d {
    transform-style: preserve-3d;
  }

  .backface-hidden {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .my-rotate-y-180 {
    transform: rotateY(180deg);
  }

  .influence-container {
    perspective: 1500px;
  }

  .group:hover .my-rotate-y-180 {
    transform: rotateY(180deg);
  }
  
  /* Tailwind doesn't have native 3D rotate utilities by default without a plugin, 
     so we define them here to ensure they work. */
  .group:hover .influence-inner {
    transform: rotateY(180deg);
  }
</style>
