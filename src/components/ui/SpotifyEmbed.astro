---
interface Props {
  spotifyId: string;
}

const { spotifyId } = Astro.props;
---

<div class="spotify-container relative w-full aspect-[4/3] min-h-[352px] rounded-xl overflow-hidden bg-black/40 border border-white/5 shadow-2xl group transition-all duration-500 hover:border-accent/40">
  <iframe 
    style="border-radius:12px" 
    src={`https://open.spotify.com/embed/playlist/${spotifyId}?utm_source=generator&theme=0`} 
    width="100%" 
    height="100%" 
    frameBorder="0" 
    allowfullscreen="" 
    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" 
    loading="lazy"
    class="opacity-90 group-hover:opacity-100 transition-opacity duration-500"
  ></iframe>
  
  <!-- Subtle Gradient Overlay -->
  <div class="absolute inset-0 pointer-events-none bg-gradient-to-t from-black/20 to-transparent"></div>
</div>

<style>
  .spotify-container {
    mask-image: linear-gradient(to bottom, black 95%, transparent 100%);
  }
</style>
