---
import ProjectDetailPage from '@components/templates/ProjectDetailPage.astro';
export const prerender = true;

const projectContent = {
  title: "The 'Cost of Quality'",
  subtitle: "Lovgivningsmæssige shocks til børnearbejde og fertilitetstransitionen i det 19. århundredes Storbritannien.",
  executiveSummary: "Dette projekt undersøger, hvordan Factory Acts af 1833 og 1844 fungerede som en katalysator for den britiske fertilitetstransition. Ved at begrænse børns arbejdstimer og indføre obligatorisk skolegang for fabriksbørn, øgede lovgivningen de implicitte omkostninger ved høj fertilitet og fremmede et skift mod 'Quantity-Quality' trade-off.",
  researchQuestions: [
    "Fungerede restriktioner på børnearbejde som et negativt indkomsthock for familier, der reducerede incitamentet til høj fertilitet?",
    "Øgede de obligatoriske skolekrav prisen på 'børnekvalitet'?",
    "Oplevede tekstiltunge distrikter en hurtigere fertilitetsnedgang efter lovgivningsshocksene sammenlignet med landbrugsdistrikter?"
  ],
  methodology: {
    model: "Difference-in-Differences (DiD)",
    strategy: "Sammenligning af Registered Sub-Districts (RSDs) med høj tekstilintensitet (treatment) mod landbrugsdistrikter (control).",
    data: "Paneldata fra 'Populations Past' (University of Cambridge) dækkende 1851-1891.",
    estimation: "OLS og Fixed Effects (District & Year) regressionsmodeller."
  },
  keyFindings: [
    "Lovgivningsmæssige begrænsninger på børnearbejde korrelerer stærkt med en accelereret nedgang i Total Fertility Rate (TFR).",
    "Mekanismen bag faldet er primært drevet af øgede alternativomkostninger ved børnepasning og uddannelse.",
    "Effekten er mest udtalt i distrikter, der var afhængige af vand- og dampdrevet tekstilindustri."
  ],
  secondaryAnalysis: {
    title: "Geospatial Analyse",
    description: "Brug af GeoPandas til at kortlægge den rumlige korrelation mellem industri-intensitet og fertilitetsmønstre.",
