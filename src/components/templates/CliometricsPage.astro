---
import Layout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import HistoricalIndicators from '@components/ui/HistoricalIndicators';
import StructuralTransformation from '@components/ui/StructuralTransformation.astro';
import { getEntry } from 'astro:content';

interface Props {
  lang: 'da' | 'en';
}

const { lang } = Astro.props;
const isDa = lang === 'da';

const entry = await getEntry('pages', `${lang}/cliometrics`);
if (!entry) throw new Error(`Missing content for ${lang}/cliometrics`);
const content: any = entry.data;
---

<Layout title={content.title} description={content.description}>
  <main class="bg-[#050505] min-h-screen text-white pt-32 pb-24 relative overflow-hidden">
    
    <!-- Background Elements -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-copper/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-accent/5 rounded-full blur-[100px] pointer-events-none"></div>

    <Section class="container mx-auto px-4 mb-24 animate-on-scroll">
      <div class="max-w-4xl">
        <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-copper mb-6">{content.hero.eyebrow}</p>
        <h1 class="text-6xl md:text-8xl font-black leading-[0.9] mb-12 uppercase italic">
          {content.hero.title}
        </h1>
        <p class="text-xl md:text-2xl text-white/50 leading-relaxed font-serif italic max-w-2xl">
          {content.hero.text}
        </p>
      </div>
    </Section>

    <!-- Indicators Dashboard -->
    <Section class="container mx-auto px-4 mb-32 animate-on-scroll delay-100">
      <HistoricalIndicators lang={lang} client:visible />
    </Section>

    <!-- Clio's Toolkit (Methodology Grid) -->
    <Section class="container mx-auto px-4 mb-32 animate-on-scroll" aria-label={content.toolkit.title}>
        <div class="mb-16">
            <h2 class="text-xs font-bold uppercase tracking-[0.5em] text-copper mb-4">{content.toolkit.title}</h2>
            <p class="text-dim text-sm max-w-2xl font-mono">// {content.toolkit.desc}</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {content.toolkit.items.map(item => (
                <div class="p-8 bg-white/[0.02] border border-white/5 hover:border-copper/20 rounded-2xl transition-all group">
                    <div class="w-10 h-10 rounded-lg bg-copper/10 flex items-center justify-center mb-6 group-hover:bg-copper/20 transition-colors">
                        <i class={`${item.icon} text-copper text-lg`} aria-hidden="true"></i>
                    </div>
                    <h3 class="text-sm font-bold text-white uppercase tracking-widest mb-3">{item.name}</h3>
                    <p class="text-xs text-dim leading-relaxed font-serif italic mb-4">
                        {item.desc}
                    </p>
                </div>
            ))}
        </div>
    </Section>

    <!-- Philosophy & Approach -->
    <Section class="container mx-auto px-4 mb-32 animate-on-scroll">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div>
                <h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter mb-8 italic">
                    {content.philosophy.title}
                </h2>
                <p class="text-white/40 mb-12 text-lg font-serif italic leading-relaxed">
                    {content.philosophy.text}
                </p>
                <div class="space-y-6">
                    {content.philosophy.points.map(point => (
                        <div class="flex items-start gap-4 group">
                            <div class="w-1.5 h-1.5 rounded-full bg-copper mt-2 group-hover:scale-150 transition-transform"></div>
                            <p class="text-sm text-dim uppercase tracking-wider group-hover:text-white transition-colors">{point}</p>
                        </div>
                    ))}
                </div>
            </div>
            
            <div class="relative">
                <div class="aspect-square rounded-3xl overflow-hidden border border-white/10 bg-white/[0.02] p-8 flex items-center justify-center">
                    <i class="fa-solid fa-hourglass-start text-[200px] text-copper/10 absolute rotate-12" aria-hidden="true"></i>
                    <div class="relative z-10 text-center p-6 bg-black/40 backdrop-blur-md rounded-2xl">
                        <p class="text-3xl font-black italic uppercase tracking-tighter mb-4">"The past is a foreign country; they do things differently there."</p>
                        <p class="text-[10px] uppercase font-bold text-copper/60 tracking-widest">— L.P. Hartley</p>
                    </div>
                </div>
            </div>
        </div>
    </Section>

    <!-- Archivist's Log (Field Journal) -->
    <Section class="container mx-auto px-4 mb-32 animate-on-scroll">
        <div class="max-w-4xl mx-auto">
            <div class="flex items-center gap-4 mb-16">
                <div class="h-[1px] flex-1 bg-gradient-to-r from-transparent to-copper/30"></div>
                <h2 class="text-xs font-bold uppercase tracking-[0.5em] text-copper">{content.archivistLog.title}</h2>
                <div class="h-[1px] flex-1 bg-gradient-to-l from-transparent to-copper/30"></div>
            </div>

            <div class="space-y-24">
                {content.archivistLog.stories.map((story, i) => (
                    <div class={`flex flex-col md:flex-row gap-12 items-start ${i % 2 !== 0 ? 'md:flex-row-reverse' : ''}`}>
                        <div class="md:w-1/3">
                            <span class="text-[10px] uppercase font-mono tracking-widest text-copper/60 block mb-3">// {story.tag}</span>
                            <h3 class="text-2xl font-black text-white uppercase italic tracking-tight">{story.title}</h3>
                        </div>
                        <div class="md:w-2/3 border-l md:border-l-0 md:border-r border-copper/10 pl-8 md:pl-0 md:pr-12 md:text-right" class:list={[{ 'md:border-r-0 md:border-l md:pl-12 md:text-left': i % 2 !== 0 }]}>
                            <p class="text-white/50 leading-relaxed font-serif italic text-lg">
                                {story.text}
                            </p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </Section>

    <!-- GIS Gallery -->
    <Section class="container mx-auto px-4 mb-32 animate-on-scroll">
        <div class="text-center mb-16">
            <h2 class="text-xs font-bold uppercase tracking-[0.5em] text-copper mb-4">{content.gisGallery.title}</h2>
            <p class="text-white/40 font-serif italic">{content.gisGallery.desc}</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            {content.gisGallery.maps.map(map => (
                <div class="group">
                    <div class="relative aspect-video rounded-[32px] overflow-hidden border border-white/10 mb-8 bg-white/[0.02]">
                        <img 
                            src={map.image} 
                            alt={map.title} 
                            class="w-full h-full object-cover grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 group-hover:scale-105"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
                    </div>
                    <h4 class="text-xl font-black uppercase italic text-white mb-3 group-hover:text-copper transition-colors">{map.title}</h4>
                    <p class="text-sm text-dim leading-relaxed font-serif italic line-clamp-2">
                        {map.desc}
                    </p>
                </div>
            ))}
        </div>
    </Section>

    <!-- Featured Projects -->
    <Section class="container mx-auto px-4 mb-32 animate-on-scroll">
        <div class="mb-16">
            <h2 class="text-xs font-bold uppercase tracking-[0.5em] text-copper mb-4 text-center">{content.projects.title}</h2>
            <div class="h-[1px] w-24 bg-copper/30 mx-auto"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {content.projects.list.map(project => (
                <a href={project.url} class="group block p-8 bg-white/[0.01] hover:bg-white/[0.03] border border-white/5 hover:border-copper/30 rounded-3xl transition-all duration-500">
                    <h3 class="text-2xl font-black mb-4 uppercase italic group-hover:text-copper transition-colors">{project.title}</h3>
                    <p class="text-sm text-dim leading-relaxed font-serif italic mb-6">
                        {project.desc}
                    </p>
                    <div class="flex items-center gap-2 text-[10px] font-bold uppercase text-copper/60 group-hover:text-copper">
                        {isDa ? 'Se Projectanalyse' : 'View Project Analysis'} <i class="fa-solid fa-arrow-right"></i>
                    </div>
                </a>
            ))}
        </div>
    </Section>

    <!-- Replication Dashboard -->
    <Section id="replication" class="container mx-auto px-4 mb-32 animate-on-scroll">
        <div class="mb-16">
            <h2 class="text-xs font-bold uppercase tracking-[0.5em] text-copper mb-4">{content.replication.title}</h2>
            <p class="text-dim text-sm max-w-2xl font-mono">// {content.replication.desc}</p>
        </div>
        
        <div class="overflow-x-auto border border-white/5 rounded-3xl bg-white/[0.01] backdrop-blur-sm">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/10 uppercase text-[10px] tracking-widest text-copper">
                        <th class="p-6 font-bold">{isDa ? 'Projekt' : 'Project'}</th>
                        <th class="p-6 font-bold">Stack</th>
                        <th class="p-6 font-bold">Data</th>
                        <th class="p-6 font-bold">Access</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    {content.replication.items.map(item => (
                        <tr class="border-b border-white/5 hover:bg-white/[0.02] transition-colors group">
                            <td class="p-6">
                                <div class="font-bold text-white mb-1">{item.title}</div>
                                <div class="text-[10px] text-dim font-mono">{item.doi}</div>
                            </td>
                            <td class="p-6 font-mono text-xs text-white/60">{item.stack}</td>
                            <td class="p-6 text-xs italic font-serif text-dim">{item.data}</td>
                            <td class="p-6">
                                <a href={item.repo} class="inline-flex items-center gap-2 text-copper hover:text-white transition-colors">
                                    <i class="fa-brands fa-github"></i> <span class="text-[10px] font-bold uppercase tracking-tighter">{isDa ? 'Hent Kode' : 'Get Code'}</span>
                                </a>
                            </td>
                        </tr>
                    ))}
                </tbody>
            </table>
        </div>
    </Section>

    <!-- Identification Strategy -->
    <Section id="methodology" class="container mx-auto px-4 mb-32 animate-on-scroll">
        <div class="max-w-4xl mx-auto p-12 bg-copper/5 border border-copper/10 rounded-[40px] relative overflow-hidden">
            <div class="absolute -top-24 -right-24 w-64 h-64 bg-copper/10 blur-[100px] rounded-full"></div>
            
            <div class="relative z-10">
                <h2 class="text-xs font-bold uppercase tracking-[0.5em] text-copper mb-8">{content.methodology.title}</h2>
                <h3 class="text-3xl font-black italic uppercase tracking-tighter mb-6">{content.methodology.caseStudy.title}</h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
                    <div>
                        <p class="text-[10px] uppercase font-bold text-copper/60 tracking-widest mb-3">// Research Context</p>
                        <p class="text-dim font-serif italic leading-relaxed">{content.methodology.caseStudy.context}</p>
                    </div>
                    <div>
                        <p class="text-[10px] uppercase font-bold text-copper/60 tracking-widest mb-3">// Identification Strategy</p>
                        <p class="text-dim font-serif italic leading-relaxed">{content.methodology.caseStudy.identification}</p>
                    </div>
                </div>

                <div class="p-8 bg-black/40 rounded-2xl border border-white/5 text-center">
                    <p class="text-[10px] uppercase font-mono tracking-widest text-copper/40 mb-6">Structural Model Spec:</p>
                    <code class="text-2xl md:text-3xl font-mono text-white/90 tracking-tighter">
                        {content.methodology.caseStudy.math}
                    </code>
                </div>
            </div>
        </div>
    </Section>

    <!-- Reading Room -->
    <Section id="library" class="container mx-auto px-4 mb-32 animate-on-scroll">
        <div class="text-center mb-16">
            <h2 class="text-xs font-bold uppercase tracking-[0.5em] text-copper mb-4">{content.library.title}</h2>
            <p class="text-white/40 font-serif italic max-w-xl mx-auto">{content.library.desc}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {content.library.books.map(book => (
                <div class="p-8 border-l border-white/5 hover:border-copper/40 transition-colors">
                    <span class="text-[10px] font-mono text-copper mb-4 block">{book.author} ({book.year})</span>
                    <h4 class="text-lg font-black uppercase italic mb-4 tracking-tight">{book.title}</h4>
                    <p class="text-xs text-dim leading-relaxed font-serif italic">
                        {book.impact}
                    </p>
                </div>
            ))}
        </div>
    </Section>

    <!-- Family History Anchor -->
    <Section id="family-history" class="container mx-auto px-4 mb-32 animate-on-scroll">
        <StructuralTransformation lang={lang} />
    </Section>


  </main>
</Layout>

<style>
    :root {
        --copper: #b87333;
    }
    .text-copper { color: var(--copper); }
    .bg-copper\/5 { background-color: rgba(184, 115, 51, 0.05); }
</style>
